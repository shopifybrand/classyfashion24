      w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];ttq.methods=["page","track","identify","instances","debug","on","off","once","ready","alias","group","enable","disable"],ttq.setAndDefer=function(t,e){t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}};for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);ttq.instance=function(t){for(var e=ttq._iq[t]||[],n=0;n<e.length;n++)e[n].apply(w.ttq,arguments);return w.ttq},ttq._iq=ttq._iq||{},ttq._iq[t]||=[].push(arguments);},
